{
  "name": "remix-starter-template",
  "compatibility_date": "2025-10-08",
  "main": "./server.ts",
  "assets": {
    "directory": "./build/client"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "previews": {
    "vars": {
      "PREVIEW_ENV": "OVERRIDDEN-BY-CONFIG",
      "EXTRA_VAR": "only-in-config"
    }
  }
}
